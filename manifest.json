{
  "manifest_version": 3,
  "name": "chat-gpt-better-experience",
  "version": "1.0.155",
  "description": "Auto-sends ChatGPT dictation transcripts, with optional Temporary Chat auto-enable and chat list auto-expand.",
  "permissions": ["storage", "downloads"],
  "background": {
    "service_worker": "dist/background.js",
    "scripts": ["dist/background.js"]
  },
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pageClipboardHook.js", "pageTranscribeHook.js"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ],
  "action": {
    "default_title": "chat-gpt-better-experience",
    "default_popup": "dist/popup.html",
    "default_icon": {
      "16": "dist/icons/icon16.png",
      "32": "dist/icons/icon32.png",
      "48": "dist/icons/icon48.png",
      "96": "dist/icons/icon96.png",
      "128": "dist/icons/icon128.png",
      "256": "dist/icons/icon256.png"
    }
  },
  "icons": {
    "16": "dist/icons/icon16.png",
    "32": "dist/icons/icon32.png",
    "48": "dist/icons/icon48.png",
    "96": "dist/icons/icon96.png",
    "128": "dist/icons/icon128.png",
    "256": "dist/icons/icon256.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-dictation-autosend@qqrm-tools"
    }
  },
  "homepage_url": "https://github.com/qqrm/ChatGPT-Dictation-Auto-Send"
}
