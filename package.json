{
  "name": "chatgpt-dictation-auto-send",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "scripts": {
    "build": "node scripts/run-quiet.mjs --label build --script build:raw",
    "build:raw": "node scripts/build.mjs",
    "mock-gpt": "npm run build && node scripts/mock-gpt-server.mjs",
    "mock-gpt:serve": "node scripts/mock-gpt-server.mjs",
    "firefox:dev": "pwsh -File scripts/firefox-container.ps1 -Action start",
    "firefox:dev:logs": "pwsh -File scripts/firefox-container.ps1 -Action logs",
    "firefox:dev:screenshot": "pwsh -File scripts/firefox-container.ps1 -Action screenshot",
    "firefox:dev:status": "pwsh -File scripts/firefox-container.ps1 -Action status",
    "firefox:dev:stop": "pwsh -File scripts/firefox-container.ps1 -Action stop",
    "firefox:vm": "pwsh -File scripts/firefox-vm.ps1 -Action start",
    "firefox:vm:logs": "pwsh -File scripts/firefox-vm.ps1 -Action logs",
    "firefox:vm:reset-profile": "pwsh -File scripts/firefox-vm.ps1 -Action reset-profile",
    "firefox:vm:screenshot": "pwsh -File scripts/firefox-vm.ps1 -Action screenshot",
    "firefox:vm:status": "pwsh -File scripts/firefox-vm.ps1 -Action status",
    "firefox:vm:stop": "pwsh -File scripts/firefox-vm.ps1 -Action stop",
    "lint:amo": "node scripts/run-quiet.mjs --label lint:amo --script lint:amo:raw",
    "lint:amo:raw": "npx web-ext@9.3.0 lint --source-dir dist",
    "build:amo": "node scripts/run-quiet.mjs --label build:amo --script build:amo:raw",
    "build:amo:raw": "npx web-ext@9.3.0 build --source-dir dist --artifacts-dir web-ext-artifacts --overwrite-dest",
    "verify:ci": "node scripts/verify-ci.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "lint": "node scripts/run-quiet.mjs --label lint --script lint:raw",
    "lint:raw": "eslint . --config config/tooling/eslint.config.mjs",
    "format:check": "node scripts/run-quiet.mjs --label format:check --script format:check:raw",
    "format:check:raw": "prettier --check . --config config/tooling/prettier.config.json --ignore-path config/tooling/prettier.ignore",
    "format:write": "prettier --write . --config config/tooling/prettier.config.json --ignore-path config/tooling/prettier.ignore",
    "typecheck": "node scripts/run-quiet.mjs --label typecheck --script typecheck:raw",
    "typecheck:raw": "tsc --noEmit -p config/tooling/tsconfig.json",
    "verify": "node scripts/verify.mjs",
    "prepare": "husky",
    "test": "node scripts/run-quiet.mjs --label test --script test:raw",
    "test:raw": "vitest run --config config/tooling/vitest.config.ts",
    "test:watch": "vitest --config config/tooling/vitest.config.ts",
    "verify:ci:fix": "npm run format:write && npm run verify:ci"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --config config/tooling/eslint.config.mjs",
      "prettier --write --config config/tooling/prettier.config.json --ignore-path config/tooling/prettier.ignore"
    ],
    "*.{js,mjs,cjs,json,md,html,css,scss,yml,yaml}": [
      "prettier --write --config config/tooling/prettier.config.json --ignore-path config/tooling/prettier.ignore"
    ]
  },
  "dependencies": {
    "@rrweb/record": "^2.0.0-alpha.18",
    "@rrweb/types": "^2.0.0-alpha.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.56.0",
    "esbuild": "^0.27.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18",
    "jsdom": "^28.1.0"
  }
}
