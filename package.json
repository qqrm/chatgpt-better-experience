{
  "name": "chatgpt-dictation-auto-send",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,html,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "esbuild": "^0.27.2",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18",
    "jsdom": "^28.0.0"
  }
}
